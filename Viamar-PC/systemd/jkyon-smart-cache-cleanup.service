[Unit]
Description=jKyon Smart Cleanup (Remove old cache/trash files)

[Service]
Type=oneshot
ExecStart=/home/jkyon/ShellScript/Tools/smart-cache-cleanup/smart-cache-cleanup.sh --delete
# Ensure display and session bus are available for notify-send:
Environment=DISPLAY=:0
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/%U/bus
CPUWeight=20
IOWeight=20
Nice=19

[Install]
WantedBy=default.target
